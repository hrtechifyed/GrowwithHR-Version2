{
  "name": "growitwithhr",
  "version": "0.18.0",
  "description": "GrowItWithHR Compliance Monitoring Engine",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.11.0",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "googleapis": "^173.0.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "zustand": "^5.0.2"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "validate:compliance": "node scripts/validate-compliance-data.mjs",
    "test:ux": "jest apps/web/src/components/UX/__tests__ --passWithNoTests",
    "test:frontend": "node tests/frontend-production-checks.js",
    "test:journeys": "node tests/assessment-journey-checks.js",
    "test:baseline": "node tests/baseline-contract-checks.js",
    "test:m1": "node tests/m1-v3-contract-checks.js",
    "test:m2": "node tests/m2-traceability-contract-checks.mjs && node tests/m2-recommendation-evaluator-checks.mjs && node tests/m2-traceability-adapter-checks.mjs",
    "test:m3": "node tests/m3-compliance-story-contract-checks.mjs",
    "test:static": "node tests/requirements-static-check.js",
    "test:report-scenarios": "node tests/report-dynamic-scenarios.js",
    "test:golden": "node tests/golden-scenario-checks.js",
    "test": "npm run test:baseline && npm run test:m1 && npm run test:m2 && npm run test:m3 && npm run test:static && npm run test:frontend && npm run test:journeys && npm run test:report-scenarios && npm run test:golden && npm run test:ux",
    "test:release": "npm run version:check && npm run validate:compliance && npm test",
    "test:release:e2e": "playwright test tests/e2e/executive-assessment-modules.spec.ts tests/e2e/analyze-company-current.spec.ts tests/e2e/analyze-company-v3.spec.ts tests/e2e/analyze-company-v3-traceability.spec.ts tests/e2e/analyze-company-v3-compliance-story.spec.ts --project=chromium",
    "test:e2e": "playwright test",
    "test:advisory": "playwright test tests/e2e/analyze-company-current.spec.ts",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check"
  }
}
