    {
      "priority": "Immediate",
      "title": "Employment Documentation Review",
      "timeline": "0-30 Days",
      "reason": "Ensure offer letters, contracts and onboarding documentation are maintained."
    },
    {
      "priority": "Short Term",
      "title": "Payroll Compliance Review",
      "timeline": "30-90 Days",
      "reason": "Periodic payroll reviews reduce statutory risk."
    },
    {
      "priority": "Short Term",
      "title": "POSH Framework Assessment",
      "timeline": "30-90 Days",
      "reason": "Review workplace harassment prevention obligations."
