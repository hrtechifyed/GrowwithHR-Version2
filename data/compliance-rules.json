  "recommendedHRActions": [
    {
      "priority": 1,
      "title": "Create Employee Handbook",
      "timeline": "0-30 Days",
      "recommendedWhen": "Employee count exceeds 10",
      "benefit": "Improves governance and employee clarity."
    },
    {
      "priority": 2,
      "title": "Implement Performance Management Framework",
      "timeline": "30-90 Days",
      "recommendedWhen": "Employee count exceeds 20",
      "benefit": "Improves accountability and growth planning."
    },
    {
      "priority": 3,
      "title": "Develop Manager Capability Program",
      "timeline": "60-180 Days",
      "recommendedWhen": "Multiple reporting layers exist",
      "benefit": "Reduces people-management risk."
    },
    {
      "priority": 4,
      "title": "Establish Workforce Planning Process",
      "timeline": "90-365 Days",
      "recommendedWhen": "Business is scaling rapidly",
      "benefit": "Improves hiring efficiency and workforce forecasting."
    }
  ],

