# Gmail account used to send customer and internal emails.
GMAIL_USER=youraccount@gmail.com

# Google App Password for the Gmail account.
# Do not enter your normal Gmail password.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional internal address that receives lead notifications.
INTERNAL_NOTIFICATION_EMAIL=admin@yourdomain.com

# Optional address used when the customer clicks Reply.
REPLY_TO_EMAIL=support@yourdomain.com

# Local/server port.
PORT=3000
