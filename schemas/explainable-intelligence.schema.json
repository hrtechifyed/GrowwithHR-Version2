{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://growwithhr.hrtechify.com/schemas/explainable-intelligence.schema.json",
  "title": "GrowWithHR M4 Explainable Intelligence",
  "type": "object",
  "required": ["modelVersion", "schemaVersion", "generatedAt", "metrics", "questions", "decisionTrace", "safeguards"],
  "properties": {
    "modelVersion": { "const": "0.19.0-m4-explainable-intelligence" },
    "schemaVersion": { "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "metrics": {
      "type": "object",
      "required": ["profileCompleteness", "applicabilityCertainty", "evidenceCoverage"],
      "additionalProperties": false,
      "properties": {
        "profileCompleteness": { "$ref": "#/$defs/metric" },
        "applicabilityCertainty": { "$ref": "#/$defs/metric" },
        "evidenceCoverage": { "$ref": "#/$defs/metric" }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "dimension", "estimatedInformationGain", "rationale", "answerKeys"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "dimension": { "enum": ["profileCompleteness", "applicabilityCertainty", "evidenceCoverage"] },
          "estimatedInformationGain": { "type": "integer", "minimum": 0, "maximum": 100 },
          "rationale": { "type": "string", "minLength": 1 },
          "answerKeys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "nextBestQuestion": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/question" }] },
    "decisionTrace": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["step", "operation", "explanation"],
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "operation": { "type": "string", "minLength": 1 },
          "value": {},
          "explanation": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "safeguards": {
      "type": "object",
      "required": ["noBlendedPercentage", "deterministic", "modifiesProtectedState", "legalCertification", "indiaOperationsOnly"],
      "properties": {
        "noBlendedPercentage": { "const": true },
        "deterministic": { "const": true },
        "modifiesProtectedState": { "const": false },
        "legalCertification": { "const": false },
        "indiaOperationsOnly": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["value", "basis"],
      "properties": {
        "value": { "type": "integer", "minimum": 0, "maximum": 100 },
        "basis": { "type": "string", "minLength": 1 },
        "answeredWeight": { "type": "number", "minimum": 0 },
        "totalWeight": { "type": "number", "minimum": 0 },
        "evaluatedRules": { "type": "integer", "minimum": 0 },
        "certainRules": { "type": "integer", "minimum": 0 },
        "evidencedItems": { "type": "integer", "minimum": 0 },
        "totalItems": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "required": ["id", "label", "dimension", "estimatedInformationGain", "rationale", "answerKeys"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "dimension": { "type": "string" },
        "estimatedInformationGain": { "type": "integer" },
        "rationale": { "type": "string" },
        "answerKeys": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
